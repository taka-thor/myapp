<%# <style>
  * { outline: 1px solid red; }
</style> %>


<section class="px-6 pb-12">
  <div class="mx-auto max-w-4xl rounded-[28px] bg-white/60 p-6 shadow-[0_12px_30px_rgba(122,90,58,0.2)]">
    <div class="text-center mt-2 mb-6">
      <h2 class="inline-block px-4 py-2 rounded-full bg-[#C88951] text-white text-2xl font-bold">
        各部屋の表示について
      </h2>
    </div>

    <ol class="space-y-8 mt-8">
      <li class="rounded-2xl border border-slate-100 p-4 sm:p-6 shadow-sm bg-white/70">
        <div class="space-y-3">
          <p class="text-center text-xl font-semibold text-[#C88951]">
            話題
          </p>

          <div class="space-y-3 text-lg text-slate-700 leading-relaxed">
            <p class="text-lg text-slate-700 leading-relaxed">
              各部屋カードの中央には
              <span class="inline-flex items-center rounded-md bg-slate-100 px-2 py-0.5 text-sm font-bold tracking-[0.16em] text-slate-500">
                話題
              </span>
              が表示されます。
            </p>
            <p>
              入室前に、どんな会話テーマの部屋かを確認できます。
            </p>
          </div>

          <div class="mt-2">
            <div class="relative w-full rounded-xl
                        aspect-[16/9] flex items-center justify-center text-xs
                        text-slate-400 bg-white/40">
              <%= image_tag "各部屋の説明.png", class: "rounded-xl" %>
            </div>
          </div>
        </div>
      </li>

      <li class="rounded-2xl border border-slate-100 p-4 sm:p-6 shadow-sm bg-white/70">
        <div class="space-y-3">
          <p class="text-center text-xl font-semibold text-[#C88951]">
            参加人数
          </p>

          <div class="space-y-3 text-lg text-slate-700 leading-relaxed">
            <p>
              各部屋の右上には参加人数
              <span class="inline-flex items-center gap-1 rounded-full bg-slate-200 text-white text-sm font-semibold px-2.5 py-1 align-middle">
                <span aria-hidden="true">👤</span> 2
              </span>
              が表示されます。
            </p>
            <div class="text-center">
            </div>
            <p>
              リアルタイムで入室者を表示しています。最大4人の同時通話ができます。
            </p>
          </div>
        </div>
      </li>
    </ol>
  </div>
</section>

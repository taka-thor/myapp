<% content_for(:title, t('.title')) %>

<div class="min-h-screen w-full max-w-[700px] mx-auto flex flex-col">

  <%# --- ヘッダー（ユーザー情報表示） --- %>
  <%= render "shared/header" %>

  <main class="flex-1 px-6 pb-10 pt-12 space-y-10">

    <%# --- こえきちアイコン + 吹き出し（左上） --- %>
    <section class="flex items-start gap-3">

      <%# 小さめアイコン %>
      <div class="w-20 h-20 rounded-full overflow-hidden shadow-md shrink-0">
        <img
          src="<%= asset_path 'こえきち首輪ver.png' %>"
          alt="こえきち"
          class="w-full h-full object-cover"
        />
      </div>

      <%# 吹き出し（左向き） %>
      <div class="relative bg-white shadow-md rounded-2xl px-4 py-3 text-slate-800 text-sm sm:text-base leading-relaxed">
        お気軽にご利用ください

        <div class="absolute -left-2 top-4 w-0 h-0
                    border-t-[8px] border-t-transparent
                    border-b-[8px] border-b-transparent
                    border-r-[12px] border-r-white">
        </div>
      </div>

    </section>

    <%# --- メニュー部分 --- %>
    <section class="space-y-6 pt-3" data-controller="home-install">
      <%= render "home_room_entry" %>
      <%= render "home_friend_invitation" %>
      <%= render "home_install_prompt" %>
      <%# <%= render "home_shop_entry" %>
    </section>

  </main>
</div>

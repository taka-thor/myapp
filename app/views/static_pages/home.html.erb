<% content_for(:title, t('.title')) %>

<div class="min-h-screen w-full max-w-[700px] mx-auto flex flex-col">

  <%# --- ヘッダー（ユーザー情報表示） --- %>
  <%= render "shared/header" %>

  <main class="flex-1 px-6 pb-10 pt-12 space-y-10">

    <%# --- こえきちアイコン + 吹き出し（左上） --- %>
    <section class="flex items-start gap-3">

      <%# 小さめアイコン %>
      <div class="w-20 h-20 rounded-full overflow-hidden shadow-md shrink-0">
        <img
          src="<%= asset_path 'こえきち首輪ver.png' %>"
          alt="こえきち"
          class="w-full h-full object-cover"
        />
      </div>

      <%# 吹き出し（左向き） %>
      <div class="relative bg-white shadow-md rounded-2xl px-4 py-3 text-slate-800 text-sm sm:text-base leading-relaxed">
        お気軽にご利用ください

        <div class="absolute -left-2 top-4 w-0 h-0
                    border-t-[8px] border-t-transparent
                    border-b-[8px] border-b-transparent
                    border-r-[12px] border-r-white">
        </div>
      </div>

    </section>

    <%# --- メニュー部分 --- %>
    <section class="space-y-6 pt-3" data-controller="home-install">

      <%# 1. 通話部屋を探す %>
      <%= link_to rooms_path, data: { turbo: true }, class: "block" do %>
        <div
          class="w-full rounded-2xl bg-white/80 shadow-md
                  px-5 py-5 sm:px-6 sm:py-6
                  flex items-center justify-between gap-4
                  transition-transform duration-150 hover:scale-[1.02] active:scale-95"
        >
          <div class="flex items-center gap-3">
            <div class="flex items-center justify-center w-12 h-12 rounded-full bg-emerald-100">
              <span class="text-2xl sm:text-3xl" role="img">🗣️</span>
            </div>

            <div>
              <p class="text-base sm:text-lg font-semibold text-slate-900">
                通話部屋を探す
              </p>
              <p class="text-xs sm:text-sm text-slate-600">
                参加できる通話部屋を一覧から探します
              </p>
            </div>
          </div>

        </div>
      <% end %>

      <div
        class="w-full rounded-2xl bg-white/80 shadow-md
                px-5 py-5 sm:px-6 sm:py-6
                space-y-4"
      >
        <div class="flex items-center gap-3">
          <div class="flex items-center justify-center w-12 h-12 rounded-full bg-sky-100">
            <span class="text-2xl sm:text-3xl" role="img">👥</span>
          </div>

          <div>
            <p class="text-base sm:text-lg font-semibold text-slate-900">
              友達に紹介する
            </p>
            <p class="text-xs sm:text-sm text-slate-600">
              QRコードまたはメールでシェアできます
            </p>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <%= link_to "QRコードで紹介", qrcodes_index_path,
                class: "inline-flex items-center justify-center rounded-xl bg-sky-500 px-3 py-2 text-sm font-semibold text-white" %>

          <%= mail_to "",
                "メールで紹介",
                subject: "声友のご紹介",
                body: "無料グループ通話アプリ「声友」は、個人情報は一切不要でご利用頂けます。\\nhttps://app.rails-kt.com",
                class: "inline-flex items-center justify-center rounded-xl bg-emerald-500 px-3 py-2 text-sm font-semibold text-white" %>
        </div>
      </div>

      <section>
        <div class="w-full rounded-2xl bg-white/80 shadow-md px-5 py-5 sm:px-6 sm:py-6 space-y-4">
          <div class="flex items-center gap-3">
            <div class="flex items-center justify-center w-12 h-12 rounded-full bg-indigo-100">
              <span class="text-2xl sm:text-3xl" role="img">📲</span>
            </div>
            <div>
              <p class="text-base sm:text-lg font-semibold text-slate-900">
                ホーム画面に追加する
              </p>
              <p class="text-xs sm:text-sm text-slate-600">
                端末に合わせて追加方法を案内します
              </p>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-3">
            <button
              type="button"
              data-action="home-install#install"
              class="inline-flex items-center justify-center rounded-xl border border-indigo-300 bg-indigo-100 px-3 py-2 text-sm font-semibold text-indigo-900"
            >
              Android用
            </button>

            <button
              type="button"
              data-action="home-install#toggleIosSteps"
              class="inline-flex items-center justify-center rounded-xl border border-slate-300 bg-slate-100 px-3 py-2 text-sm font-semibold text-slate-900"
            >
              iPhone用
            </button>
          </div>

          <p class="text-sm text-slate-700">
            Android：ボタンを押すと追加確認モーダルが表示されます。
          </p>
          <p data-home-install-target="status" class="text-xs text-slate-500"></p>

          <div class="space-y-2">
            <p class="text-sm text-slate-700">
              iPhone：Safari で次の手順を実行してください。
            </p>
            <ol data-home-install-target="iosSteps" class="hidden list-decimal pl-5 space-y-2 text-sm text-slate-700">
              <li>このページを Safari で開きます。</li>
              <li>画面下の共有ボタン（□↑）をタップします。</li>
              <li>メニューを下へスクロールし、「ホーム画面に追加」をタップします。</li>
              <li>名前を確認し、右上の「追加」をタップします。</li>
              <li>ホーム画面に「声友」アイコンが追加されたら完了です。</li>
            </ol>
          </div>
        </div>
      </section>

      <%= link_to "#", class: "block" do %>
        <div
          class="w-full rounded-2xl bg-white/80 shadow-md
                  px-5 py-5 sm:px-6 sm:py-6
                  flex items-center justify-between gap-4
                  transition-transform duration-150 hover:scale-[1.02] active:scale-95"
        >
          <div class="flex items-center gap-3">

            <div class="flex items-center justify-center w-12 h-12 rounded-full bg-yellow-100">
              <span class="text-2xl sm:text-3xl" role="img">🛍️</span>
            </div>

            <div>
              <p class="text-base sm:text-lg font-semibold text-slate-900">
                ショップに行く(開発中)
              </p>
              <p class="text-xs sm:text-sm text-slate-600">
                アイテムやアイコンをチェックできます
              </p>
            </div>

          </div>

        </div>
      <% end %>

    </section>

  </main>
</div>

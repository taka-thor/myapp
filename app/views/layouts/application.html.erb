<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8">
    <title><%= content_for(:title) || "声友" %></title>
    <% og_title = content_for(:title) || "声友" %>
    <% og_description = "かんたん音声通話アプリ「声友」" %>
    <% og_url = request.original_url %>
    <% og_image = "#{request.base_url}#{image_path('top.png')}" %>
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="声友">
    <meta property="og:url" content="<%= og_url %>">
    <meta property="og:title" content="<%= og_title %>">
    <meta property="og:description" content="<%= og_description %>">
    <meta property="og:image" content="<%= og_image %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= og_title %>">
    <meta name="twitter:description" content="<%= og_description %>">
    <meta name="twitter:image" content="<%= og_image %>">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <% if ENV["GA_MEASUREMENT_ID"].present? %>
      <meta name="ga-measurement-id" content="<%= ENV["GA_MEASUREMENT_ID"] %>">
    <% end %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#f7f0e6">

    <link rel="icon" href="/pwa-icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/pwa-icon.png">

    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=M+PLUS+Rounded+1c:wght@400;700&display=swap">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  </head>

  <body
  class="min-h-screen bg-white flex items-center justify-center"
  style="font-family: 'M PLUS Rounded 1c', system-ui, sans-serif;"
>
  <div class="w-full max-w-[425px] min-h-screen bg-[rgba(248,201,139,0.45)] flex items-center justify-center">
    <%= yield %>
  </div>
</body>

</html>
